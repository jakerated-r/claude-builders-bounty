      "id": "ed8ab7d5-b1c9-4039-afcb-11ca53887496",
      "name": "GitHub: Merged PRs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_GITHUB_CRED",
          "name": "GitHub API (Header Auth)"
        }
