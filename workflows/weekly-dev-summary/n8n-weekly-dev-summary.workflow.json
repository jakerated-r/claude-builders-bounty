    {
      "parameters": {
        "jsCode": "// Compute the 7-day window (YYYY-MM-DD) and carry config forward.\nconst cfg = $input.first().json;\nconst d = new Date();\nd.setDate(d.getDate() - 7);\nconst sinceISO = d.toISOString().slice(0, 10);\nreturn [{ json: { ...cfg, sinceISO } }];"
      },
      "id": "884de85e-ea8e-43c6-9b80-475d7b35ceb8",
      "name": "Compute Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/search/commits?q=repo:{{ $('Compute Window').first().json.githubOwner }}/{{ $('Compute Window').first().json.githubRepo }}+committer-date:>={{ $('Compute Window').first().json.sinceISO }}&per_page=50",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
