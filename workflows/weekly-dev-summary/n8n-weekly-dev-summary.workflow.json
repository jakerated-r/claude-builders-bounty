    },
    {
      "parameters": {
        "url": "=https://api.github.com/search/issues?q=repo:{{ $('Compute Window').first().json.githubOwner }}/{{ $('Compute Window').first().json.githubRepo }}+is:issue+is:closed+closed:>={{ $('Compute Window').first().json.sinceISO }}&per_page=50",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
