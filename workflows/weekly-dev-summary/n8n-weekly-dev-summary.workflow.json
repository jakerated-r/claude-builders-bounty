      "id": "c99e0bb2-b2c9-42d1-8498-1287a2ead953",
      "name": "GitHub: Closed Issues",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_GITHUB_CRED",
          "name": "GitHub API (Header Auth)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Gather GitHub results and build the Claude API payload.\nconst cw      = $('Compute Window').first().json;\nconst commits = $('GitHub: Commits').first().json || {};\nconst prs     = $('GitHub: Merged PRs').first().json || {};\nconst issues  = $('GitHub: Closed Issues').first().json || {};\n\nconst repo = `${cw.githubOwner}/${cw.githubRepo}`;\nconst lang = String(cw.language || 'EN').toUpperCase() === 'FR' ? 'French' : 'English';\n\nconst commitList = (commits.items || [])\n  .map(c => `- ${(c.commit && c.commit.message ? c.commit.message.split('\\n')[0] : '')} (${(c.sha||'').slice(0,7)})`)\n  .slice(0, 50).join('\\n');\nconst prList = (prs.items || []).map(p => `- #${p.number} ${p.title}`).slice(0, 50).join('\\n');\nconst issueList = (issues.items || []).map(i => `- #${i.number} ${i.title}`).slice(0, 50).join('\\n');\n\nconst system = `You are a senior engineering writer. Write a concise, factual weekly development `\n  + `summary for the GitHub repository ${repo}, in ${lang}. Use three short sections: `\n  + `Highlights, Shipped (merged PRs + notable commits), and Housekeeping (closed issues). `\n  + `Keep it under 250 words. Never invent activity that is not in the data; if a section is `\n  + `empty, say so in one line.`;\n\nconst user = `Week since ${cw.sinceISO}.\\n\\n`\n  + `Merged PRs (${prs.total_count || 0}):\\n${prList || '(none)'}\\n\\n`\n  + `Closed issues (${issues.total_count || 0}):\\n${issueList || '(none)'}\\n\\n`\n  + `Commits (${commits.total_count || 0}):\\n${commitList || '(none)'}`;\n\nconst claudePayload = {\n  model: 'claude-sonnet-4-20250514',\n  max_tokens: 1024,\n  system,\n  messages: [{ role: 'user', content: user }],\n};\nreturn [{ json: { claudePayload, repo, lang } }];"
      },
      "id": "73e31cdb-6b45-4db4-b3e1-4aff378c17bd",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.claudePayload }}",
        "options": {}
      },
      "id": "f1c602b9-23c5-4737-a2f4-412312e4c584",
      "name": "Claude (Messages API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1780,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_ANTHROPIC_CRED",
          "name": "Anthropic API (x-api-key)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract Claude's text and build the destination webhook body.\nconst resp = $input.first().json || {};\nconst text = (resp.content && resp.content[0] && resp.content[0].text)\n  ? resp.content[0].text\n  : '(no summary returned)';\nconst cfg = $('Compute Window').first().json;\nconst repo = `${cfg.githubOwner}/${cfg.githubRepo}`;\nlet deliveryBody;\nif (String(cfg.destinationType || 'discord').toLowerCase() === 'slack') {\n  deliveryBody = { text: `*Weekly Dev Summary \u2014 ${repo}*\\n\\n${text}` };\n} else {\n  deliveryBody = { content: `**Weekly Dev Summary \u2014 ${repo}**\\n\\n${text}`.slice(0, 1900) };\n}\nreturn [{ json: { summaryText: text, deliveryBody } }];"
      },
      "id": "e08f418d-366f-44b4-a7b3-0922d2fa2510",
      "name": "Format Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Compute Window').first().json.webhookUrl }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.deliveryBody }}",
        "options": {}
      },
      "id": "c05c4e31-2e75-45c2-9da4-e89f406f35f6",
      "name": "Deliver (Discord/Slack)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2220,
        300
      ]
    }
